    {
      "name": "Delete Test Kit",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = pm.environment.get(\"test_kit_id\");",
              "if (!id) console.warn(\"⚠️  test_kit_id chưa được set. Chạy Get All hoặc Create trước.\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const kitId   = pm.environment.get(\"test_kit_id\");",
              "const baseUrl = pm.environment.get(\"base_url\");",
              "const token   = pm.environment.get(\"access_token\");",
              "",
              "// ── STATUS ──────────────────────────────────────────",
              "pm.test(\"Status code is 204 No Content\", function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "",
              "// ── BUSINESS LOGIC: soft-delete vs hard-delete ───────",
              "// Nếu kit đã được order → setIsAvailable(false) (soft delete)",
              "// Nếu chưa được order   → deleteById (hard delete)",
              "pm.sendRequest({",
              "    url: `${baseUrl}/api/v1/test-kits/${kitId}`,",
              "    method: \"GET\",",
              "    header: { Authorization: `Bearer ${token}` }",
              "}, function (err, res) {",
              "    if (!err) {",
              "        if (res.code === 200) {",
              "            pm.test(\"Soft delete: isAvailable set to false\", function () {",
              "                pm.expect(res.json().data.isAvailable).to.be.false;",
              "            });",
              "            console.log(\"Kit đã được order → soft delete\");",
              "        } else {",
              "            pm.test(\"Hard delete: kit no longer exists\", function () {",
              "                pm.expect([400, 404, 500]).to.include(res.code);",
              "            });",
              "            console.log(\"Kit chưa được order → hard delete\");",
              "        }",
              "    }",
              "});",
              "",
              "// ── CLEANUP ─────────────────────────────────────────",
              "pm.environment.unset(\"test_kit_id\");",
              "console.log(\"test_kit_id cleared from environment\");",
              "",
              "// ── PERFORMANCE ─────────────────────────────────────",
              "pm.test(\"Response time < 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
