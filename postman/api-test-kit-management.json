              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ── WRAPPER STRUCTURE ───────────────────────────────",
              "pm.test(\"Response has standard wrapper\", function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property(\"code\", 200);",
              "    pm.expect(json).to.have.property(\"message\");",
              "    pm.expect(json).to.have.property(\"data\");",
              "    pm.expect(json).to.have.property(\"timestamp\");",
              "});",
              "",
              "// ── TOKEN FIELDS ────────────────────────────────────",
              "pm.test(\"data has access_token, refresh_token, expires_in\", function () {",
              "    const data = pm.response.json().data;",
              "    pm.expect(data).to.have.property(\"access_token\").that.is.a(\"string\").and.not.empty;",
              "    pm.expect(data).to.have.property(\"refresh_token\").that.is.a(\"string\").and.not.empty;",
              "    pm.expect(data).to.have.property(\"expires_in\");",
              "});",
              "",
              "pm.test(\"access_token is a valid JWT (3 parts)\", function () {",
              "    const token = pm.response.json().data.access_token;",
              "    pm.expect(token.split(\".\")).to.have.lengthOf(3);",
              "});",
              "",
              "// ── SAVE TO ENV ─────────────────────────────────────",
              "const data = pm.response.json().data;",
              "if (data && data.access_token) {",
              "    pm.environment.set(\"access_token\", data.access_token);",
              "    pm.environment.set(\"refresh_token\", data.refresh_token);",
              "    pm.environment.set(\"expires_in\", data.expires_in);",
              "    console.log(\"✅ Token saved to environment\");",
              "}"
