    {
      "name": "Get Test Kit with paginated",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "const data = json.data;",
              "",
              "// ── STATUS ──────────────────────────────────────────",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ── WRAPPER STRUCTURE ───────────────────────────────",
              "pm.test(\"Response has standard wrapper\", function () {",
              "    pm.expect(json).to.have.property(\"code\", 200);",
              "    pm.expect(json).to.have.property(\"message\");",
              "    pm.expect(json).to.have.property(\"data\");",
              "    pm.expect(json).to.have.property(\"timestamp\");",
              "});",
              "",
              "// ── PAGINATION STRUCTURE ────────────────────────────",
              "pm.test(\"data contains pageable content\", function () {",
              "    pm.expect(data).to.be.an(\"object\");",
              "    pm.expect(data).to.have.property(\"content\").that.is.an(\"array\");",
              "    pm.expect(data).to.have.property(\"pageNumber\");",
              "    pm.expect(data).to.have.property(\"pageSize\");",
              "    pm.expect(data).to.have.property(\"totalElements\");",
              "    pm.expect(data).to.have.property(\"totalPages\");",
              "    pm.expect(data).to.have.property(\"last\");",
              "});",
              "",
              "pm.test(\"pageNumber is 0 (first page)\", function () {",
              "    pm.expect(data.pageNumber).to.eql(0);",
              "});",
              "",
              "pm.test(\"pageSize is 10\", function () {",
              "    pm.expect(data.pageSize).to.eql(10);",
              "});",
              "",
              "pm.test(\"totalElements >= 0\", function () {",
              "    pm.expect(data.totalElements).to.be.at.least(0);",
              "});",
              "",
              "// ── ITEM SCHEMA (nếu có data) ────────────────────────",
              "if (data.content.length > 0) {",
              "    const item = data.content[0];",
              "",
              "    pm.test(\"Each item has required fields\", function () {",
              "        pm.expect(item).to.include.all.keys(",
              "            \"id\", \"kitName\", \"kitType\", \"sampleType\",",
              "            \"basePrice\", \"currentPrice\", \"quantityInStock\", \"isAvailable\"",
              "        );",
              "    });",
              "",
              "    pm.test(\"id is a positive number\", function () {",
              "        pm.expect(item.id).to.be.a(\"number\").and.above(0);",
              "    });",
              "",
              "    pm.test(\"basePrice >= 0\", function () {",
              "        pm.expect(Number(item.basePrice)).to.be.at.least(0);",
              "    });",
              "",
              "    pm.test(\"currentPrice >= 0\", function () {",
              "        pm.expect(Number(item.currentPrice)).to.be.at.least(0);",
              "    });",
              "",
              "    pm.test(\"quantityInStock >= 0\", function () {",
              "        pm.expect(item.quantityInStock).to.be.at.least(0);",
              "    });",
              "",
              "    pm.test(\"isAvailable is boolean\", function () {",
              "        pm.expect(item.isAvailable).to.be.a(\"boolean\");",
              "    });",
              "",
              "    // Lưu ID đầu tiên để dùng cho các request sau",
              "    pm.environment.set(\"test_kit_id\", item.id);",
              "    console.log(\"test_kit_id set to:\", item.id);",
              "}",
              "",
              "// ── PERFORMANCE ─────────────────────────────────────",
              "pm.test(\"Response time < 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
