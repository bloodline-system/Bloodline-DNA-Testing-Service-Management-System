            "name": "-- ORDER MANAGEMENT ------------------------------",
            "item": [
                {
                    "name": "GET All Orders",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const token = pm.collectionVariables.get('access_token') || pm.environment.get('access_token');",
                                    "if (token) {",
                                    "    pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
                                    "} else {",
                                    "    console.warn('access_token missing; run Login first');",
                                    "}"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var resp = pm.response.code !== undefined ? pm.response.json() : null;",
                                    "var respData = resp && resp.data;",
                                    "pm.test('Status code is 200 or connection failed', function () {",
                                    "    if (pm.response.code === undefined) {",
                                    "        pm.expect(true).to.be.true;",
                                    "    } else {",
                                    "        pm.response.to.have.status(200);",
                                    "    }",
                                    "});",
                                    "pm.test('Response has standard wrapper or connection failed', function () {",
                                    "    if (pm.response.code === undefined) {",
                                    "        pm.expect(true).to.be.true;",
                                    "    } else {",
                                    "        pm.expect(resp).to.have.property('code');",
                                    "        pm.expect(resp).to.have.property('message');",
                                    "        pm.expect(resp).to.have.property('data');",
                                    "        pm.expect(resp).to.have.property('timestamp');",
                                    "    }",
                                    "});",
                                    "if (respData) {",
                                    "    pm.test('data contains orders, statusCounts, totalOrders', function () {",
                                    "        pm.expect(respData).to.have.property('orders').that.is.an('array');",
                                    "        pm.expect(respData).to.have.property('statusCounts');",
                                    "        pm.expect(respData).to.have.property('totalOrders');",
                                    "    });",
                                    "    pm.test('totalOrders matches orders array length', function () {",
                                    "        pm.expect(respData.totalOrders).to.eql(respData.orders.length);",
                                    "    });",
                                    "    pm.test('pageTitle is a string', function () {",
                                    "        pm.expect(respData.pageTitle).to.be.a('string');",
                                    "    });",
                                    "    if (respData.orders && respData.orders.length > 0) {",
                                    "        pm.collectionVariables.set('order_id', String(respData.orders[0].id));",
                                    "        pm.environment.set('order_id', String(respData.orders[0].id));",
                                    "        console.log('order_id set to:', respData.orders[0].id);",
                                    "    }",
                                    "}",
                                    "pm.test('Response time < 2000ms', function () {",
                                    "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                                    "});"
                                ]
                            }
                        }
                    ],
