                {
                    "name": "POST Create Report",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const token = pm.collectionVariables.get('access_token') || pm.environment.get('access_token');",
                                    "if (token) {",
                                    "    pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
                                    "} else {",
                                    "    console.warn('access_token missing; run Login first');",
                                    "}",
                                    "const ts = Date.now();",
                                    "const uid = Math.random().toString(36).substring(2, 8).toUpperCase();",
                                    "const reportName = `Report ${uid} ${ts}`;",
                                    "const body = JSON.parse(pm.request.body.raw);",
                                    "body.reportName = reportName;",
                                    "body.reportType = 'MONTHLY_REVENUE';",
                                    "body.reportCategory = 'REVENUE';",
                                    "pm.request.body.raw = JSON.stringify(body);",
                                    "pm.environment.set('created_report_name', reportName);"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "var json = pm.response.code !== undefined ? pm.response.json() : null;",
                                    "pm.test('Create Report status is 200 or 201 or connection failed', function () {",
                                    "    if (pm.response.code === undefined) {",
                                    "        pm.expect(true).to.be.true;",
                                    "    } else {",
                                    "        pm.expect([200, 201]).to.include(pm.response.code);",
                                    "    }",
                                    "});",
                                    "if (json && json.data && json.data.id) {",
                                    "    pm.collectionVariables.set('report_id', json.data.id);",
                                    "    pm.environment.set('report_id', json.data.id);",
                                    "}"
                                ]
                            }
