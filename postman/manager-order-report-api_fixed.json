                  "    pm.test('data contains orders, statusCounts, totalOrders', function () {",
                  "        pm.expect(data).to.have.property('orders').that.is.an('array');",
                  "        pm.expect(data).to.have.property('statusCounts');",
                  "        pm.expect(data).to.have.property('totalOrders');",
                  "    });",
                  "    pm.test('totalOrders matches orders array length', function () {",
                  "        pm.expect(data.totalOrders).to.eql(data.orders.length);",
                  "    });",
