    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const response = pm.response.json();",
              "if (response && response.data) {",
              "    pm.environment.set(\"access_token\", response.data.access_token);",
              "    pm.environment.set(\"refresh_token\", response.data.refresh_token);",
              "    pm.environment.set(\"expires_in\", response.data.expires_in);",
              "}",
              "pm.test(\"Login response contains tokens\", function () {",
              "    pm.expect(response).to.have.property(\"data\");",
              "    if (response.data) {",
              "        pm.expect(response.data).to.have.property(\"access_token\");",
              "        pm.expect(response.data).to.have.property(\"refresh_token\");",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin1234\",\n  \"rememberMe\": true\n}"
        },
        "url": {
