{
  "info": {
    "_postman_id": "452d4eaf-67b6-4e46-af63-b252d167bb0f",
    "name": "Employee Management API",
    "description": "Quản lý Nhân viên - DNA Testing System  \nCho phép quản trị viên quản lý thông tin và phân công công việc cho đội ngũ nhân viên.\n\nChức năng:\n\n1. Đăng nhập\n    \n2. Cập nhật thông tin nhân viên (chức vụ, phòng ban, liên hệ)\n    \n3. Xóa / vô hiệu hóa tài khoản nhân viên đã nghỉ việc\n    \n4. Phân quyền và gán vai trò (Manager, Staff)\n    \n5. Xem lịch sử công việc và đơn xét nghiệm nhân viên đã xử lý\n    \n\nResponse wrapper format:  \n{  \n\"code\": 200,  \n\"message\": \"...\",  \n\"data\": { ... },  \n\"timestamp\": \"...\"  \n}\n\nDefault credentials (seed data):\n\n- Admin : admin / admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "39783418",
    "_collection_link": "https://go.postman.co/collection/39783418-452d4eaf-67b6-4e46-af63-b252d167bb0f?source=collection_link"
  },
  "item": [
    {
      "name": "1. Đăng Nhập Admin",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "if (jsonData.data) {",
                  "    pm.environment.set(\"access_token\", jsonData.data.access_token);",
                  "    pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "    pm.environment.set(\"expires_in\", jsonData.data.expires_in);",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Tự động refresh token nếu hết hạn",
                  "const token = pm.environment.get(\"access_token\");",
                  "const expiresIn = pm.environment.get(\"expires_in\");",
                  "",
                  "// expires_in là date string dạng \"Sun Mar 15 15:31:29 GMT+07:00 2026\"",
                  "const expiry = expiresIn ? new Date(expiresIn).getTime() : 0;",
                  "",
                  "if (!token || Date.now() > expiry) {",
                  "  // Gọi API refresh token",
                  "  pm.sendRequest({",
                  "    url: pm.environment.get(\"baseUrl\") + \"/api/v1/auth/refresh\",",
                  "    method: \"POST\",",
                  "    header: { \"Content-Type\": \"application/json\" },",
                  "    body: {",
                  "      mode: \"raw\",",
                  "      raw: JSON.stringify({ token: pm.environment.get(\"refresh_token\") })",
                  "    }",
                  "  }, (err, res) => {",
                  "    if (!err && res) {",
                  "      const data = res.json().data;",
                  "      if (data) {",
                  "        pm.environment.set(\"access_token\", data.access_token);",
                  "        pm.environment.set(\"refresh_token\", data.refresh_token);",
                  "        pm.environment.set(\"expires_in\", data.expires_in);",
                  "      }",
                  "    }",
                  "  });",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"admin\",\r\n  \"password\": \"admin1234\",\r\n  \"rememberMe\": true\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Xem Danh Sách & Thông Tin Nhân Viên",
      "item": [
        {
          "name": "Get All Employees (Paginated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has standard wrapper\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"code\");",
                  "    pm.expect(body).to.have.property(\"message\");",
                  "    pm.expect(body).to.have.property(\"data\");",
                  "    pm.expect(body).to.have.property(\"timestamp\");",
                  "});",
                  "",
                  "pm.test(\"Data contains users list and pagination\", function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.data).to.be.an(\"object\");",
                  "    pm.expect(body.data).to.have.property(\"users\").that.is.an(\"array\");",
                  "    pm.expect(body.data).to.have.property(\"totalElements\");",
                  "    pm.expect(body.data).to.have.property(\"totalPages\");",
                  "    pm.expect(body.data).to.have.property(\"currentPage\");",
                  "});",
                  "",
                  "pm.test(\"Lưu admin_user_id từ danh sách nhân viên STAFF\", function () {",
                  "    const body = pm.response.json();",
                  "    if (body.data && body.data.users && body.data.users.length > 0) {",
                  "        const staffUser = body.data.users.find(u =>",
                  "            u.userRoles && u.userRoles.some(r => r.role && r.role.roleName === \"STAFF\")",
                  "        );",
                  "        const target = staffUser || body.data.users[0];",
                  "        pm.environment.set(\"admin_user_id\", target.id);",
                  "        pm.expect(target.id).to.be.a(\"string\");",
                  "    }",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/admin/dashboard/users?page=0&size=20&sortBy=createdAt&sortDir=desc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "dashboard",
                "users"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                },
                {
                  "key": "sortBy",
                  "value": "createdAt"
                },
                {
                  "key": "sortDir",
                  "value": "desc"
                }
              ]
            }
          },
          "response": []
        },
