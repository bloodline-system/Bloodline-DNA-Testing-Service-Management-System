  "item": [
    {
      "name": "🔐 AUTH",
      "description": "Chạy Login trước — token tự động lưu vào environment",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "// ── HTTP ──────────────────────────────────────────────",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Content-Type là application/json', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "",
                  "// ── Business ──────────────────────────────────────────",
                  "pm.test('[Business] data.accessToken là string không rỗng', () => {",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Business] data.refreshToken là string không rỗng', () => {",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Business] data.accessToken dạng JWT (3 phần phân cách bởi .)', () => {",
                  "  pm.expect(json.data.accessToken.split('.').length).to.eql(3);",
                  "});",
                  "",
                  "// ── Lưu token ─────────────────────────────────────────",
                  "if (json.data?.accessToken) {",
                  "  pm.environment.set('access_token', json.data.accessToken);",
                  "  pm.environment.set('refresh_token', json.data.refreshToken);",
                  "  console.log('✅ Tokens saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"rememberMe\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Đăng nhập — access_token & refresh_token tự động lưu vào environment."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📄 MANAGER – REPORTS",
      "item": [
        {
          "name": "GET /reports — Danh sách báo cáo",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const d = json.data;",
                  "",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "pm.test('[Business] data.reports là array', () => pm.expect(d.reports).to.be.an('array'));",
                  "pm.test('[Business] data.stats là object', () => pm.expect(d.stats).to.be.an('object'));",
                  "pm.test('[Business] stats.totalReports >= 0', () => pm.expect(d.stats.totalReports).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] stats.approvedReports + rejectedReports + generatedReports <= totalReports', () => {",
                  "  pm.expect(d.stats.approvedReports + d.stats.rejectedReports + d.stats.generatedReports).to.be.at.most(d.stats.totalReports);",
                  "});",
                  "pm.test('[Business] data.currentPage == 0', () => pm.expect(d.currentPage).to.eql(0));",
                  "pm.test('[Business] data.pageSize == 20', () => pm.expect(d.pageSize).to.eql(20));",
                  "pm.test('[Business] data.totalPages >= 0', () => pm.expect(d.totalPages).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.reportStatuses là array không rỗng', () => pm.expect(d.reportStatuses).to.be.an('array').and.not.empty);",
                  "pm.test('[Business] data.reportTypes là array không rỗng', () => pm.expect(d.reportTypes).to.be.an('array').and.not.empty);",
                  "pm.test('[Business] Mỗi report có id, reportName, reportStatus, reportType', () => {",
                  "  d.reports.forEach(r => {",
                  "    pm.expect(r).to.have.property('id');",
                  "    pm.expect(r).to.have.property('reportName');",
                  "    pm.expect(r).to.have.property('reportStatus');",
                  "    pm.expect(r).to.have.property('reportType');",
                  "  });",
                  "});",
                  "if (d.reports.length > 0) {",
                  "  pm.environment.set('reportId', d.reports[0].id);",
                  "  console.log('reportId saved:', d.reports[0].id);",
                  "}"
                ]
              }
            }
          ],
