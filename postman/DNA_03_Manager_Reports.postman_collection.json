                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 201', () => {",
                  "  pm.expect(json.code).to.eql(201);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "pm.test('[Business] data.id tồn tại (id mới được tạo)', () => pm.expect(d.id).to.exist);",
                  "pm.test('[Business] data.reportName == tên đã gửi', () => pm.expect(d.reportName).to.eql('Báo cáo tháng 3/2026'));",
                  "pm.test('[Business] data.reportType == MONTHLY', () => pm.expect(d.reportType).to.eql('MONTHLY'));",
                  "pm.test('[Business] data.reportCategory == DNA_ORDERS', () => pm.expect(d.reportCategory).to.eql('DNA_ORDERS'));",
                  "pm.test('[Business] data.reportStatus == GENERATED (trạng thái mặc định khi mới tạo)', () => pm.expect(d.reportStatus).to.eql('GENERATED'));",
                  "pm.test('[Business] data.generatedByUserName tồn tại (lấy từ token)', () => pm.expect(d.generatedByUserName).to.exist);",
                  "if (d?.id) { pm.environment.set('reportId', d.id); console.log('New reportId:', d.id); }"
                ]
              }
            }
