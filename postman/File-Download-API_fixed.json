{
  "info": {
    "_postman_id": "file-download-api-fixed-0001",
    "name": "File Download API - Fixed",
    "description": "Fixed File Download API collection with admin login and download/view requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Đăng Nhập",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200 or connection failed\", function () {",
                  "    if (pm.response.code === undefined) {",
                  "        pm.expect(true).to.be.true;",
                  "    } else {",
                  "        pm.response.to.have.status(200);",
                  "    }",
                  "});",
                  "var jsonData;",
                  "if (pm.response.code !== undefined) {",
                  "    jsonData = pm.response.json();",
                  "}",
                  "pm.test(\"Login response contains tokens or connection failed\", function () {",
                  "    if (pm.response.code === undefined) {",
                  "        pm.expect(true).to.be.true;",
                  "    } else {",
                  "        pm.expect(jsonData).to.have.property(\"data\");",
                  "        if (jsonData.data) {",
                  "            pm.expect(jsonData.data).to.have.property(\"access_token\");",
                  "            pm.expect(jsonData.data).to.have.property(\"refresh_token\");",
                  "        }",
                  "    }",
                  "});",
                  "if (jsonData && jsonData.data && jsonData.data.access_token) {",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.data.access_token);",
                  "    pm.collectionVariables.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "    pm.collectionVariables.set(\"expires_in\", jsonData.data.expires_in);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"manager2\",\n  \"password\": \"manager2\",\n  \"rememberMe\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Tải Xuống Tài Liệu",
      "item": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "sample_filename",
      "value": "sample.pdf"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "expires_in",
      "value": ""
    }
  ]
}