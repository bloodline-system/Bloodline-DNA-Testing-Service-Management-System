{
  "info": {
    "_postman_id": "file-download-api-fixed-0001",
    "name": "File Download API - Fixed",
    "description": "Fixed File Download API collection with admin login and download/view requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Đăng Nhập",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Login response contains tokens\", function () {",
                  "    pm.expect(jsonData).to.have.property(\"data\");",
                  "    if (jsonData.data) {",
                  "        pm.expect(jsonData.data).to.have.property(\"access_token\");",
                  "        pm.expect(jsonData.data).to.have.property(\"refresh_token\");",
                  "    }",
                  "});",
                  "if (jsonData.data && jsonData.data.access_token) {",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.data.access_token);",
                  "    pm.collectionVariables.set(\"refresh_token\", jsonData.data.refresh_token);",
                  "    pm.collectionVariables.set(\"expires_in\", jsonData.data.expires_in);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"manager2\",\n  \"password\": \"manager2\",\n  \"rememberMe\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Tải Xuống Tài Liệu",
      "item": [
        {
          "name": "Download File (Attachment)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var token = pm.collectionVariables.get('access_token') || pm.environment.get('access_token');",
                  "if (token) {",
                  "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
                  "} else {",
                  "    console.warn('access_token missing; run Login first');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has Content-Disposition attachment', function () {",
                  "    var disposition = pm.response.headers.get('Content-Disposition');",
                  "    pm.expect(disposition).to.be.a('string').and.include('attachment');",
                  "});",
                  "pm.test('Response has proper content type', function () {",
                  "    var contentType = pm.response.headers.get('Content-Type');",
                  "    pm.expect(contentType).to.not.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/files/download?filename={{sample_filename}}",
              "host": ["{{baseUrl}}"],
              "path": ["files", "download"],
              "query": [{ "key": "filename", "value": "{{sample_filename}}" }]
            }
          }
        },
        {
          "name": "View File (Inline)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var token = pm.collectionVariables.get('access_token') || pm.environment.get('access_token');",
                  "if (token) {",
                  "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
                  "} else {",
                  "    console.warn('access_token missing; run Login first');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has Content-Disposition inline', function () {",
                  "    var disposition = pm.response.headers.get('Content-Disposition');",
                  "    pm.expect(disposition).to.be.a('string').and.include('inline');",
                  "});",
                  "pm.test('Response has proper content type', function () {",
                  "    var contentType = pm.response.headers.get('Content-Type');",
                  "    pm.expect(contentType).to.not.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/files/view?filename={{sample_filename}}",
              "host": ["{{baseUrl}}"],
              "path": ["files", "view"],
              "query": [{ "key": "filename", "value": "{{sample_filename}}" }]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "sample_filename", "value": "sample.pdf" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "expires_in", "value": "" }
  ]
}
