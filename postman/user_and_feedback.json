        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const jsonData = pm.response.json();\r",
                  "if (jsonData.code === 200) {\r",
                  "    pm.test(\"Access token is present\", function () {\r",
                  "        pm.expect(jsonData.data.access_token).to.not.be.null;\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Refresh token is present\", function () {\r",
                  "        pm.expect(jsonData.data.refresh_token).to.not.be.null;\r",
                  "        });\r",
                  "\r",
                  "    pm.test(\"Add token to environment variables\", function () {\r",
                  "        pm.environment.set(\"access_token\", jsonData.data.access_token);\r",
                  "        pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);\r",
                  "        pm.environment.set(\"expires_in\", jsonData.data.expires_in);\r",
                  "    });\r",
                  "\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
