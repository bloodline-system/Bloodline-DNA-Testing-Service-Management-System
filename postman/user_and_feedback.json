          "name": "Get Profile By Username",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200 or 404\", function () {\r",
                  "  pm.expect([200, 404]).to.include(pm.response.code);\r",
                  "});\r",
                  "const json = pm.response.json();\r",
                  "if (pm.response.code === 200) {\r",
                  "  pm.test(\"Profile payload valid\", function () {\r",
                  "    pm.expect(json.code).to.eql(200);\r",
                  "    pm.expect(json.data).to.be.an(\"object\");\r",
                  "  });\r",
