    {
      "name": "UserController",
      "item": [
        {
          "name": "Get All Profiles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", function () {\r",
                  "  pm.response.to.have.status(200);\r",
                  "});\r",
                  "const json = pm.response.json();\r",
                  "pm.test(\"Get all profiles success\", function () {\r",
                  "  pm.expect(json.code).to.eql(200);\r",
                  "  pm.expect(json.data).to.be.an(\"array\");\r",
                  "});\r",
                  "if (json.data.length > 0 && json.data[0].username) {\r",
                  "  pm.environment.set(\"profile_username\", json.data[0].username);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token_user}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{access_token_user}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/profiles/all",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "profiles",
                "all"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Search Profiles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "let json;\r",
                  "\r",
                  "pm.test(\"Response is valid JSON\", function () {\r",
                  "json = pm.response.json();\r",
                  "pm.expect(json).to.be.an(\"object\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has ApiResponse structure\", function () {\r",
                  "pm.expect(json).to.have.property(\"code\");\r",
                  "pm.expect(json).to.have.property(\"message\");\r",
                  "pm.expect(json).to.have.property(\"data\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"API returns success code\", function () {\r",
                  "pm.expect(json.code).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Data is an array of profiles\", function () {\r",
                  "pm.expect(json.data).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Each profile has required fields\", function () {\r",
                  "if (json.data.length > 0) {\r",
                  "let profile = json.data[0];\r",
                  "\r",
                  "```\r",
                  "    pm.expect(profile).to.have.property(\"id\");\r",
                  "    pm.expect(profile).to.have.property(\"username\");\r",
                  "    pm.expect(profile).to.have.property(\"email\");\r",
                  "}\r",
                  "```\r",
                  "\r",
                  "});\r",
                  "\r",
                  "// Save first profile info for next APIs\r",
                  "if (json.data.length > 0) {\r",
                  "pm.environment.set(\"profile_id\", json.data[0].id);\r",
                  "pm.environment.set(\"profile_username\", json.data[0].username);\r",
                  "\r",
                  "```\r",
                  "console.log(\"Saved profile_id and profile_username to environment\");\r",
                  "```\r",
                  "\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token_user}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/profiles/search?name={{search_name}}",
              "host": [
                "{{base_url}}"
