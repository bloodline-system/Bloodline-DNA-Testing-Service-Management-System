          "name": "GET /dna-orders — Danh sách đơn ADN",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const d = json.data;",
                  "",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Content-Type JSON', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'));",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "pm.test('[Business] data.orders là array', () => pm.expect(d.orders).to.be.an('array'));",
                  "pm.test('[Business] data.summary tồn tại', () => pm.expect(d.summary).to.be.an('object'));",
                  "pm.test('[Business] summary.totalOrders là number >= 0', () => pm.expect(d.summary.totalOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] summary.completedOrders <= summary.totalOrders', () => pm.expect(d.summary.completedOrders).to.be.at.most(d.summary.totalOrders));",
                  "pm.test('[Business] summary.cancelledOrders <= summary.totalOrders', () => pm.expect(d.summary.cancelledOrders).to.be.at.most(d.summary.totalOrders));",
                  "pm.test('[Business] data.currentPage == 0 (trang đầu)', () => pm.expect(d.currentPage).to.eql(0));",
                  "pm.test('[Business] data.pageSize == 10', () => pm.expect(d.pageSize).to.eql(10));",
                  "pm.test('[Business] data.totalPages là number >= 0', () => pm.expect(d.totalPages).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.totalOrders là number >= 0', () => pm.expect(d.totalOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.filters tồn tại', () => pm.expect(d.filters).to.be.an('object'));",
                  "pm.test('[Business] Mỗi order có id, orderStatus, customerName', () => {",
                  "  d.orders.forEach(o => {",
                  "    pm.expect(o).to.have.property('id');",
                  "    pm.expect(o).to.have.property('orderStatus');",
                  "    pm.expect(o.orderStatus).to.be.a('string').and.not.empty;",
                  "  });",
                  "});",
                  "pm.test('[Business] totalOrders khớp length nếu trang đầy đủ', () => {",
                  "  pm.expect(d.orders.length).to.be.at.most(10);",
                  "});",
                  "if (d.orders.length > 0) {",
                  "  pm.environment.set('orderId', d.orders[0].id);",
                  "  console.log('orderId saved:', d.orders[0].id);",
                  "}"
                ]
              }
            }
