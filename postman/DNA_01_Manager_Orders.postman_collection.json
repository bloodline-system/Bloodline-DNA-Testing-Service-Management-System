    {
      "name": "🔐 AUTH",
      "description": "Chạy Login trước — token tự động lưu vào environment",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "// ── HTTP ──────────────────────────────────────────────",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Content-Type là application/json', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "",
                  "// ── Business ──────────────────────────────────────────",
                  "pm.test('[Business] data.accessToken là string không rỗng', () => {",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Business] data.refreshToken là string không rỗng', () => {",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Business] data.accessToken dạng JWT (3 phần phân cách bởi .)', () => {",
                  "  pm.expect(json.data.accessToken.split('.').length).to.eql(3);",
                  "});",
                  "",
                  "// ── Lưu token ─────────────────────────────────────────",
                  "if (json.data?.accessToken) {",
                  "  pm.environment.set('access_token', json.data.accessToken);",
                  "  pm.environment.set('refresh_token', json.data.refreshToken);",
                  "  console.log('✅ Tokens saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
