    {
      "name": "Update Test Kit",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// ── AUTO REFRESH TOKEN NẾU HẾT HẠN ────────────────────",
              "const token     = pm.environment.get(\"access_token\");",
              "const refreshTk = pm.environment.get(\"refresh_token\");",
              "const baseUrl   = pm.environment.get(\"baseUrl\");",
              "",
              "if (!token) {",
              "    console.warn(\"⚠️  Không có access_token. Hãy chạy Login trước.\");",
              "} else {",
              "    // Decode JWT để kiểm tra expiry",
              "    try {",
              "        const payload = JSON.parse(atob(token.split(\".\")[1]));",
              "        const expMs   = payload.exp * 1000;",
              "        const nowMs   = Date.now();",
              "        const ttlSec  = Math.floor((expMs - nowMs) / 1000);",
              "        console.log(`🕐 Token TTL: ${ttlSec}s`);",
              "",
              "        if (ttlSec < 60 && refreshTk) {",
              "            console.log(\"🔄 Token sắp hết hạn, đang refresh...\");",
              "            pm.sendRequest({",
              "                url: `${baseUrl}/api/v1/auth/refresh`,",
              "                method: \"POST\",",
              "                header: { \"Content-Type\": \"application/json\" },",
              "                body: {",
              "                    mode: \"raw\",",
              "                    raw: JSON.stringify({ refreshToken: refreshTk })",
              "                }",
              "            }, function(err, res) {",
              "                if (!err && res.code === 200) {",
              "                    const newData = res.json().data;",
              "                    pm.environment.set(\"access_token\",  newData.access_token);",
              "                    pm.environment.set(\"refresh_token\", newData.refresh_token);",
              "                    console.log(\"✅ Token refreshed\");",
              "                } else {",
              "                    console.warn(\"❌ Refresh thất bại, chạy lại Login\");",
              "                }",
              "            });",
              "        }",
              "    } catch(e) {",
              "        console.warn(\"⚠️  Không decode được token:\", e.message);",
              "    }",
              "}",
              "",
              "const id = pm.environment.get(\"test_kit_id\");",
              "if (!id) console.warn(\"⚠️  test_kit_id chưa được set. Chạy Get All hoặc Create trước.\");",
              "",
              "// ── SINH DỮ LIỆU UPDATE NGẪU NHIÊN ─────────────────",
              "const runId      = pm.environment.get(\"created_run_id\") || Date.now();",
              "const updatedQty = Math.floor(Math.random() * 400) + 50;",
              "const updatedPrice = parseFloat((Math.random() * 50 + 5).toFixed(2));",
              "",
              "const body = JSON.parse(pm.request.body.raw);",
              "body.kitName         = `Test Kit ${runId} - Updated`;",
              "body.currentPrice    = updatedPrice;",
              "body.quantityInStock = updatedQty;",
              "body.kitDescription  = `Updated kit [${runId}] at ${Date.now()}`;",
              "pm.request.body.raw  = JSON.stringify(body);",
              "",
              "// Lưu lại để test script verify",
              "pm.environment.set(\"updated_price\", updatedPrice);",
              "pm.environment.set(\"updated_qty\",   updatedQty);",
              "console.log(\"🔧 Update | price:\", updatedPrice, \"| qty:\", updatedQty);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "",
              "// ── STATUS ──────────────────────────────────────────",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ── WRAPPER ─────────────────────────────────────────",
              "pm.test(\"Response has wrapper with code 200\", function () {",
              "    pm.expect(json).to.have.property(\"code\", 200);",
              "    pm.expect(json).to.have.property(\"message\");",
              "    pm.expect(json).to.have.property(\"timestamp\");",
              "});",
              "",
              "pm.test(\"message confirms update\", function () {",
              "    pm.expect(json.message).to.include(\"Test kit updated successfully\");",
              "});",
              "",
              "// ── VERIFY UPDATE bằng GET lại ──────────────────────",
              "const kitId        = pm.environment.get(\"test_kit_id\");",
              "const baseUrl      = pm.environment.get(\"baseUrl\");",
              "const token        = pm.environment.get(\"access_token\");",
              "const updatedPrice = parseFloat(pm.environment.get(\"updated_price\"));",
