    {
      "name": "Delete Test Kit",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// ── AUTO REFRESH TOKEN NẾU HẾT HẠN ────────────────────",
              "const token     = pm.environment.get(\"access_token\");",
              "const refreshTk = pm.environment.get(\"refresh_token\");",
              "const baseUrl   = pm.environment.get(\"baseUrl\");",
              "",
              "if (!token) {",
              "    console.warn(\"⚠️  Không có access_token. Hãy chạy Login trước.\");",
              "} else {",
              "    // Decode JWT để kiểm tra expiry",
              "    try {",
              "        const payload = JSON.parse(atob(token.split(\".\")[1]));",
              "        const expMs   = payload.exp * 1000;",
              "        const nowMs   = Date.now();",
              "        const ttlSec  = Math.floor((expMs - nowMs) / 1000);",
              "        console.log(`🕐 Token TTL: ${ttlSec}s`);",
              "",
              "        if (ttlSec < 60 && refreshTk) {",
              "            console.log(\"🔄 Token sắp hết hạn, đang refresh...\");",
              "            pm.sendRequest({",
              "                url: `${baseUrl}/api/v1/auth/refresh`,",
              "                method: \"POST\",",
              "                header: { \"Content-Type\": \"application/json\" },",
              "                body: {",
              "                    mode: \"raw\",",
              "                    raw: JSON.stringify({ refreshToken: refreshTk })",
              "                }",
              "            }, function(err, res) {",
              "                if (!err && res.code === 200) {",
              "                    const newData = res.json().data;",
              "                    pm.environment.set(\"access_token\",  newData.access_token);",
              "                    pm.environment.set(\"refresh_token\", newData.refresh_token);",
              "                    console.log(\"✅ Token refreshed\");",
              "                } else {",
              "                    console.warn(\"❌ Refresh thất bại, chạy lại Login\");",
              "                }",
              "            });",
              "        }",
              "    } catch(e) {",
              "        console.warn(\"⚠️  Không decode được token:\", e.message);",
              "    }",
              "}",
              "",
              "const id = pm.environment.get(\"test_kit_id\");",
              "if (!id) console.warn(\"⚠️  test_kit_id chưa được set. Chạy Get All hoặc Create trước.\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const kitId   = pm.environment.get(\"test_kit_id\");",
              "const baseUrl = pm.environment.get(\"baseUrl\");",
              "const token   = pm.environment.get(\"access_token\");",
              "",
              "// ── STATUS ──────────────────────────────────────────",
              "pm.test(\"Status code is 204 No Content\", function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "",
              "// ── BUSINESS LOGIC: soft-delete vs hard-delete ───────",
              "// Nếu kit đã được order → setIsAvailable(false) (soft delete)",
              "// Nếu chưa được order   → deleteById (hard delete)",
              "pm.sendRequest({",
              "    url: `${baseUrl}/api/v1/test-kits/${kitId}`,",
              "    method: \"GET\",",
              "    header: { Authorization: `Bearer ${token}` }",
              "}, function (err, res) {",
              "    if (!err) {",
              "        if (res.code === 200) {",
              "            pm.test(\"Soft delete: isAvailable set to false\", function () {",
              "                pm.expect(res.json().data.isAvailable).to.be.false;",
              "            });",
              "            console.log(\"Kit đã được order → soft delete\");",
              "        } else {",
              "            pm.test(\"Hard delete: kit no longer exists\", function () {",
              "                pm.expect([400, 404, 500]).to.include(res.code);",
              "            });",
              "            console.log(\"Kit chưa được order → hard delete\");",
              "        }",
              "    }",
              "});",
              "",
              "// ── CLEANUP ─────────────────────────────────────────",
              "pm.environment.unset(\"test_kit_id\");",
              "console.log(\"test_kit_id cleared from environment\");",
              "",
              "// ── PERFORMANCE ─────────────────────────────────────",
              "pm.test(\"Response time < 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
