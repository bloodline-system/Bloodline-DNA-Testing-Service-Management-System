        {
          "listen": "test",
          "script": {
            "exec": [
              "const resp = pm.response.json();",
              "const data = resp.data;",
              "const expectedId = parseInt(pm.environment.get(\"test_kit_id\"));",
              "",
              "// ── STATUS ──────────────────────────────────────────",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ── WRAPPER ─────────────────────────────────────────",
              "pm.test(\"Response has standard wrapper\", function () {",
              "    pm.expect(resp).to.have.property(\"code\", 200);",
              "    pm.expect(resp).to.have.property(\"message\");",
              "    pm.expect(resp).to.have.property(\"data\");",
              "    pm.expect(resp).to.have.property(\"timestamp\");",
              "});",
              "",
              "// ── DATA FIELDS ─────────────────────────────────────",
              "pm.test(\"data contains kit fields\", function () {",
              "    pm.expect(data).to.be.an(\"object\");",
              "    pm.expect(data).to.have.property(\"id\").that.is.a(\"number\");",
              "    pm.expect(data).to.have.property(\"kitName\");",
              "    pm.expect(data).to.have.property(\"kitType\");",
              "    pm.expect(data).to.have.property(\"sampleType\");",
              "    pm.expect(data).to.have.property(\"quantityInStock\");",
              "    pm.expect(data).to.have.property(\"expiryDate\");",
              "    pm.expect(data).to.have.property(\"isAvailable\").that.is.a(\"boolean\");",
              "    pm.expect(data).to.have.property(\"producedBy\");",
              "});",
              "",
              "pm.test(\"id matches requested test_kit_id\", function () {",
              "    pm.expect(data.id).to.eql(expectedId);",
              "});",
              "",
              "pm.test(\"kitType is a valid enum value\", function () {",
              "    const validTypes = [",
              "        \"PATERNITY\",\"MATERNITY\",\"SIBLING\",\"GRANDPARENT\",\"ANCESTRY\",",
              "        \"RELATIONSHIP\",\"FORENSIC\",\"IMMIGRATION\",\"PRENATAL\",",
              "        \"TWIN_ZYGOSITY\",\"GENETIC_HEALTH\",\"CARRIER_SCREENING\",",
              "        \"PHARMACOGENOMICS\",\"OTHER\"",
              "    ];",
              "    pm.expect(validTypes).to.include(data.kitType);",
              "});",
              "",
              "pm.test(\"sampleType is a valid enum value\", function () {",
              "    const validSamples = [\"BLOOD\",\"URINE\",\"SALIVA\",\"TISSUE\",\"HAIR\",\"SEMEN\",\"SWAB\",\"NAIL\",\"OTHER\"];",
              "    pm.expect(validSamples).to.include(data.sampleType);",
              "});",
              "",
              "// ── PERFORMANCE ─────────────────────────────────────",
              "pm.test(\"Response time < 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
