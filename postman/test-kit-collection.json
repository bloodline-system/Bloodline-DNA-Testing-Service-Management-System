    {
      "name": "Create Test Kit",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// ── AUTO REFRESH TOKEN NẾU HẾT HẠN ────────────────────",
              "const token     = pm.environment.get(\"access_token\");",
              "const refreshTk = pm.environment.get(\"refresh_token\");",
              "const baseUrl   = pm.environment.get(\"baseUrl\");",
              "",
              "if (!token) {",
              "    console.warn(\"⚠️  Không có access_token. Hãy chạy Login trước.\");",
              "} else {",
              "    // Decode JWT để kiểm tra expiry",
              "    try {",
              "        const payload = JSON.parse(atob(token.split(\".\")[1]));",
              "        const expMs   = payload.exp * 1000;",
              "        const nowMs   = Date.now();",
              "        const ttlSec  = Math.floor((expMs - nowMs) / 1000);",
              "        console.log(`🕐 Token TTL: ${ttlSec}s`);",
              "",
              "        if (ttlSec < 60 && refreshTk) {",
              "            console.log(\"🔄 Token sắp hết hạn, đang refresh...\");",
              "            pm.sendRequest({",
              "                url: `${baseUrl}/api/v1/auth/refresh`,",
              "                method: \"POST\",",
              "                header: { \"Content-Type\": \"application/json\" },",
              "                body: {",
              "                    mode: \"raw\",",
              "                    raw: JSON.stringify({ refreshToken: refreshTk })",
              "                }",
              "            }, function(err, res) {",
              "                if (!err && res.code === 200) {",
              "                    const newData = res.json().data;",
              "                    pm.environment.set(\"access_token\",  newData.access_token);",
              "                    pm.environment.set(\"refresh_token\", newData.refresh_token);",
              "                    console.log(\"✅ Token refreshed\");",
              "                } else {",
              "                    console.warn(\"❌ Refresh thất bại, chạy lại Login\");",
              "                }",
              "            });",
              "        }",
              "    } catch(e) {",
              "        console.warn(\"⚠️  Không decode được token:\", e.message);",
              "    }",
              "}",
              "",
              "// ── SINH DỮ LIỆU NGẪU NHIÊN ĐỂ TRÁNH DUPLICATE ────",
              "const ts  = Date.now();",
              "const uid = Math.random().toString(36).substring(2, 8).toUpperCase();",
              "const runId = `${ts}-${uid}`;",
              "",
              "const kitTypes    = [\"PATERNITY\",\"MATERNITY\",\"SIBLING\",\"PRENATAL\",\"FORENSIC\",\"ANCESTRY\"];",
              "const sampleTypes = [\"BLOOD\",\"SALIVA\",\"SWAB\",\"URINE\",\"HAIR\"];",
              "const producers   = [\"BioRapid Inc.\",\"GeneTech Lab\",\"HelixCorp\",\"DNAPlus\",\"BioScan Ltd\"];",
              "",
              "const randomKitType    = kitTypes[Math.floor(Math.random() * kitTypes.length)];",
              "const randomSampleType = sampleTypes[Math.floor(Math.random() * sampleTypes.length)];",
              "const randomProducer   = producers[Math.floor(Math.random() * producers.length)];",
              "const randomBase       = parseFloat((Math.random() * 90 + 10).toFixed(2));",
              "const randomCurrent    = parseFloat((randomBase * 0.9).toFixed(2));",
              "const randomQty        = Math.floor(Math.random() * 900) + 100;",
              "",
              "const body = JSON.parse(pm.request.body.raw);",
              "body.kitName         = `Test Kit ${uid} ${ts}`;",
              "body.kitType         = randomKitType;",
              "body.sampleType      = randomSampleType;",
              "body.basePrice       = randomBase;",
              "body.currentPrice    = randomCurrent;",
              "body.quantityInStock = randomQty;",
              "body.producedBy      = randomProducer;",
              "body.kitDescription  = `Auto-generated kit [${runId}]`;",
              "pm.request.body.raw  = JSON.stringify(body);",
              "",
              "// Lưu lại để Update dùng",
              "pm.environment.set(\"created_kit_name\", body.kitName);",
              "pm.environment.set(\"created_run_id\",   runId);",
              "console.log(\"🔧 runId:\", runId, \"| kitName:\", body.kitName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "",
              "// ── STATUS ──────────────────────────────────────────",
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// ── WRAPPER STRUCTURE ───────────────────────────────",
              "pm.test(\"Response has wrapper with code 201\", function () {",
              "    pm.expect(json).to.have.property(\"code\", 201);",
              "    pm.expect(json).to.have.property(\"message\");",
              "    pm.expect(json).to.have.property(\"timestamp\");",
              "});",
              "",
              "pm.test(\"message confirms creation\", function () {",
              "    pm.expect(json.message).to.include(\"Test kit created successfully\");",
              "});",
              "",
              "// ── SAVE ID NẾU API TRẢ VỀ ─────────────────────────",
              "if (json.data && json.data.id) {",
              "    pm.environment.set(\"test_kit_id\", json.data.id);",
              "    console.log(\"✅ test_kit_id saved:\", json.data.id);",
              "} else {",
              "    console.warn(\"⚠️  API không trả về id. Hãy chạy Get All trước để lấy test_kit_id.\");",
              "}",
              "",
              "// ── PERFORMANCE ─────────────────────────────────────",
              "pm.test(\"Response time < 3000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
