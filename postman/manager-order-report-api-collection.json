        {
            "name": "── ORDER MANAGEMENT ──────────────────────────────",
            "disabled": true,
            "item": [
                {
                    "name": "GET All Orders",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "// ── AUTO REFRESH TOKEN NẾU HẾT HẠN ────────────────────",
                                    "const token     = pm.environment.get(\"access_token\");",
                                    "const refreshTk = pm.environment.get(\"refresh_token\");",
                                    "const baseUrl   = pm.environment.get(\"baseUrl\");",
                                    "",
                                    "if (!token) {",
                                    "    console.warn(\"⚠️  Không có access_token. Hãy chạy Login trước.\");",
                                    "} else {",
                                    "    try {",
                                    "        const payload = JSON.parse(atob(token.split(\".\")[1]));",
                                    "        const ttlSec  = Math.floor((payload.exp * 1000 - Date.now()) / 1000);",
                                    "        console.log(`🕐 Token TTL: ${ttlSec}s`);",
                                    "        if (ttlSec < 60 && refreshTk) {",
                                    "            pm.sendRequest({",
                                    "                url: `${baseUrl}/api/v1/auth/refresh`,",
                                    "                method: \"POST\",",
                                    "                header: { \"Content-Type\": \"application/json\" },",
                                    "                body: { mode: \"raw\", raw: JSON.stringify({ refreshToken: refreshTk }) }",
                                    "            }, function(err, res) {",
                                    "                if (!err && res.code === 200) {",
                                    "                    const d = res.json().data;",
                                    "                    pm.environment.set(\"access_token\",  d.access_token);",
                                    "                    pm.environment.set(\"refresh_token\", d.refresh_token);",
                                    "                    console.log(\"✅ Token refreshed\");",
                                    "                } else {",
                                    "                    console.warn(\"❌ Refresh thất bại, chạy lại Login\");",
                                    "                }",
                                    "            });",
                                    "        }",
                                    "    } catch(e) {",
                                    "        console.warn(\"⚠️  Không decode được token:\", e.message);",
                                    "    }",
                                    "}"
                                ],
                                "type": "text/javascript",
                                "packages": {},
                                "requests": {}
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "(function () {",
                                    "const resp = pm.response.json();",
                                    "const data = resp.data;",
                                    "",
                                    "// ── STATUS ──────────────────────────────────────────",
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "// ── WRAPPER STRUCTURE ───────────────────────────────",
                                    "pm.test(\"Response has standard wrapper\", function () {",
                                    "    pm.expect(resp).to.have.property(\"code\", 200);",
                                    "    pm.expect(resp).to.have.property(\"message\");",
                                    "    pm.expect(resp).to.have.property(\"data\");",
                                    "    pm.expect(resp).to.have.property(\"timestamp\");",
                                    "});",
                                    "",
                                    "// ── DATA STRUCTURE ──────────────────────────────────",
                                    "pm.test(\"data contains orders, statusCounts, totalOrders\", function () {",
                                    "    pm.expect(data).to.be.an(\"object\");",
                                    "    pm.expect(data).to.have.property(\"orders\").that.is.an(\"array\");",
                                    "    pm.expect(data).to.have.property(\"statusCounts\").that.is.an(\"object\");",
                                    "    pm.expect(data).to.have.property(\"totalOrders\");",
                                    "    pm.expect(data).to.have.property(\"pageTitle\");",
                                    "});",
                                    "",
                                    "pm.test(\"totalOrders matches orders array length\", function () {",
                                    "    pm.expect(data.totalOrders).to.eql(data.orders.length);",
                                    "});",
                                    "",
                                    "pm.test(\"totalOrders >= 0\", function () {",
                                    "    pm.expect(data.totalOrders).to.be.at.least(0);",
                                    "});",
                                    "",
                                    "pm.test(\"pageTitle is 'Order Management'\", function () {",
                                    "    pm.expect(data.pageTitle).to.eql(\"Order Management\");",
                                    "});",
                                    "",
                                    "// ── ITEM SCHEMA (nếu có data) ────────────────────────",
                                    "if (data.orders && data.orders.length > 0) {",
                                    "    const firstOrder = data.orders[0];",
                                    "",
                                    "    pm.test(\"Each order has required fields\", function () {",
                                    "        pm.expect(firstOrder).to.include.all.keys(",
                                    "            \"id\", \"orderStatus\"",
                                    "        );",
                                    "    });",
                                    "",
                                    "    pm.test(\"order id is a positive number\", function () {",
                                    "        pm.expect(firstOrder.id).to.be.a(\"number\").and.above(0);",
                                    "    });",
                                    "",
                                    "    // Lưu order_id để dùng ở các request sau",
                                    "    pm.environment.set(\"order_id\", String(firstOrder.id));",
                                    "    console.log(\"✅ order_id set to:\", firstOrder.id);",
                                    "}",
                                    "",
                                    "// ── PERFORMANCE ─────────────────────────────────────",
                                    "pm.test(\"Response time < 2000ms\", function () {",
                                    "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                                    "});",
                                    "}());"
                                ],
                                "type": "text/javascript",
                                "packages": {},
                                "requests": {}
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{access_token}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/manager/orders",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "manager",
                                "orders"
                            ]
                        }
                    },
                    "response": []
                }
            ]
        },
