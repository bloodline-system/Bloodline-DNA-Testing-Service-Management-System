    "item": [
        {
            "name": "Login",
            "disabled": true,
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "// ── STATUS ──────────────────────────────────────────",
                            "pm.test(\"Status code is 200\", function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "// ── WRAPPER STRUCTURE ───────────────────────────────",
                            "pm.test(\"Response has standard wrapper\", function () {",
                            "    const resp = pm.response.json();",
                            "    pm.expect(resp).to.have.property(\"code\", 200);",
                            "    pm.expect(resp).to.have.property(\"message\");",
                            "    pm.expect(resp).to.have.property(\"data\");",
                            "    pm.expect(resp).to.have.property(\"timestamp\");",
                            "});",
                            "",
                            "// ── TOKEN FIELDS ────────────────────────────────────",
                            "pm.test(\"data has access_token, refresh_token, expires_in\", function () {",
                            "    const tokenData = pm.response.json().data;",
                            "    pm.expect(tokenData).to.have.property(\"access_token\").that.is.a(\"string\").and.not.empty;",
                            "    pm.expect(tokenData).to.have.property(\"refresh_token\").that.is.a(\"string\").and.not.empty;",
                            "    pm.expect(tokenData).to.have.property(\"expires_in\");",
                            "});",
                            "",
                            "pm.test(\"access_token is a valid JWT (3 parts)\", function () {",
                            "    const token = pm.response.json().data.access_token;",
                            "    pm.expect(token.split(\".\")).to.have.lengthOf(3);",
                            "});",
                            "",
                            "// ── SAVE TO ENV ─────────────────────────────────────",
                            "const tokenData = pm.response.json().data;",
                            "if (tokenData && tokenData.access_token) {",
                            "    pm.environment.set(\"access_token\",  tokenData.access_token);",
                            "    pm.environment.set(\"refresh_token\", tokenData.refresh_token);",
                            "    pm.environment.set(\"expires_in\",    tokenData.expires_in);",
                            "    console.log(\"✅ Token saved to environment\");",
                            "}"
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                    }
                },
                {
                    "listen": "prerequest",
                    "script": {
                        "exec": [
                            ""
                        ],
                        "type": "text/javascript",
                        "packages": {},
                        "requests": {}
                    }
                }
            ],
            "request": {
                "auth": {
                    "type": "noauth"
                },
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
