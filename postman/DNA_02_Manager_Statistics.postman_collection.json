    {
      "name": "🔐 AUTH",
      "description": "Chạy Login trước — token tự động lưu vào environment",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "// ── HTTP ──────────────────────────────────────────────",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Content-Type là application/json', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "",
                  "// ── Business ──────────────────────────────────────────",
                  "pm.test('[Business] data.accessToken là string không rỗng', () => {",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Business] data.refreshToken là string không rỗng', () => {",
                  "  pm.expect(json.data.refreshToken).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Business] data.accessToken dạng JWT (3 phần phân cách bởi .)', () => {",
                  "  pm.expect(json.data.accessToken.split('.').length).to.eql(3);",
                  "});",
                  "",
                  "// ── Lưu token ─────────────────────────────────────────",
                  "if (json.data?.accessToken) {",
                  "  pm.environment.set('access_token', json.data.accessToken);",
                  "  pm.environment.set('refresh_token', json.data.refreshToken);",
                  "  console.log('✅ Tokens saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"rememberMe\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Đăng nhập — access_token & refresh_token tự động lưu vào environment."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📊 MANAGER – STATISTICS",
      "item": [
        {
          "name": "GET /overview — Tổng quan thống kê",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const d = json.data;",
                  "",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "pm.test('[Business] data.totalOrders là number >= 0', () => pm.expect(d.totalOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.statusBreakdown là object', () => pm.expect(d.statusBreakdown).to.be.an('object'));",
                  "pm.test('[Business] data.completionRate có dấu %', () => pm.expect(d.completionRate).to.match(/%$/));",
                  "pm.test('[Business] data.cancellationRate có dấu %', () => pm.expect(d.cancellationRate).to.match(/%$/));",
                  "pm.test('[Business] data.currentMonthOrders là number >= 0', () => pm.expect(d.currentMonthOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.prevMonthOrders là number >= 0', () => pm.expect(d.prevMonthOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.monthGrowthRate có dấu %', () => pm.expect(d.monthGrowthRate).to.match(/%$/));",
                  "pm.test('[Business] data.pendingOrders là number >= 0', () => pm.expect(d.pendingOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.analyzingOrders là number >= 0', () => pm.expect(d.analyzingOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.revenue là object', () => pm.expect(d.revenue).to.be.an('object'));",
                  "pm.test('[Business] revenue.totalRevenue là number >= 0', () => pm.expect(d.revenue.totalRevenue).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] revenue.formattedTotal chứa VNĐ', () => pm.expect(d.revenue.formattedTotal).to.include('VNĐ'));",
                  "pm.test('[Business] currentMonthOrders <= totalOrders', () => pm.expect(d.currentMonthOrders).to.be.at.most(d.totalOrders));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/manager/dna-statistics/overview",
              "host": [
