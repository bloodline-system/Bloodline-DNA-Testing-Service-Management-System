        {
          "name": "GET /revenue — Thống kê doanh thu",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const d = json.data;",
                  "",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "pm.test('[Business] data.period == month', () => pm.expect(d.period).to.eql('month'));",
                  "pm.test('[Business] data.startDate định dạng date', () => pm.expect(d.startDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
                  "pm.test('[Business] data.endDate định dạng date', () => pm.expect(d.endDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
                  "pm.test('[Business] data.periodRevenue là object', () => pm.expect(d.periodRevenue).to.be.an('object'));",
                  "pm.test('[Business] periodRevenue.totalRevenue >= 0', () => pm.expect(d.periodRevenue.totalRevenue).to.be.at.least(0));",
                  "pm.test('[Business] periodRevenue.completedOrders >= 0', () => pm.expect(d.periodRevenue.completedOrders).to.be.at.least(0));",
                  "pm.test('[Business] periodRevenue.averageOrderValue >= 0', () => pm.expect(d.periodRevenue.averageOrderValue).to.be.at.least(0));",
                  "pm.test('[Business] periodRevenue.formattedTotal chứa VNĐ', () => pm.expect(d.periodRevenue.formattedTotal).to.include('VNĐ'));",
                  "pm.test('[Business] data.totalRevenue là object', () => pm.expect(d.totalRevenue).to.be.an('object'));",
                  "pm.test('[Business] totalRevenue.totalRevenue >= periodRevenue.totalRevenue', () => {",
                  "  pm.expect(d.totalRevenue.totalRevenue).to.be.at.least(d.periodRevenue.totalRevenue);",
                  "});",
                  "pm.test('[Business] data.monthlyRevenue có đúng 12 tháng', () => pm.expect(Object.keys(d.monthlyRevenue).length).to.eql(12));",
                  "pm.test('[Business] monthlyRevenue keys định dạng yyyy-MM', () => {",
                  "  Object.keys(d.monthlyRevenue).forEach(k => pm.expect(k).to.match(/^\\d{4}-\\d{2}$/));",
                  "});",
                  "pm.test('[Business] monthlyRevenue values là number >= 0', () => {",
                  "  Object.values(d.monthlyRevenue).forEach(v => pm.expect(v).to.be.a('number').and.at.least(0));",
                  "});",
                  "pm.test('[Business] averageOrderValue = totalRevenue / completedOrders (nếu > 0)', () => {",
                  "  if (d.periodRevenue.completedOrders > 0) {",
                  "    const expected = d.periodRevenue.totalRevenue / d.periodRevenue.completedOrders;",
                  "    pm.expect(d.periodRevenue.averageOrderValue).to.be.closeTo(expected, 1);",
                  "  }",
                  "});"
                ]
              }
