        {
          "name": "GET /by-period — Thống kê theo khoảng thời gian",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const d = json.data;",
                  "",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('[HTTP] Response time < 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "pm.test('[Business] data.period == month', () => pm.expect(d.period).to.eql('month'));",
                  "pm.test('[Business] data.groupBy == day', () => pm.expect(d.groupBy).to.eql('day'));",
                  "pm.test('[Business] data.startDate là string định dạng date', () => pm.expect(d.startDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
                  "pm.test('[Business] data.endDate là string định dạng date', () => pm.expect(d.endDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
                  "pm.test('[Business] startDate <= endDate', () => {",
                  "  pm.expect(new Date(d.startDate).getTime()).to.be.at.most(new Date(d.endDate).getTime());",
                  "});",
                  "pm.test('[Business] data.chartData là object (key-value)', () => pm.expect(d.chartData).to.be.an('object'));",
                  "pm.test('[Business] chartData keys có định dạng yyyy-MM-dd (groupBy=day)', () => {",
                  "  Object.keys(d.chartData).forEach(k => pm.expect(k).to.match(/^\\d{4}-\\d{2}-\\d{2}$/));",
                  "});",
                  "pm.test('[Business] chartData values là number >= 0', () => {",
                  "  Object.values(d.chartData).forEach(v => pm.expect(v).to.be.a('number').and.at.least(0));",
                  "});",
                  "pm.test('[Business] data.totalInPeriod là number >= 0', () => pm.expect(d.totalInPeriod).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.completedInPeriod <= totalInPeriod', () => pm.expect(d.completedInPeriod).to.be.at.most(d.totalInPeriod));",
                  "pm.test('[Business] data.cancelledInPeriod <= totalInPeriod', () => pm.expect(d.cancelledInPeriod).to.be.at.most(d.totalInPeriod));",
                  "pm.test('[Business] data.completionRate có dấu %', () => pm.expect(d.completionRate).to.match(/%$/));"
                ]
              }
            }
          ],
          "request": {
