        {
          "name": "GET /by-status — Thống kê theo trạng thái",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const d = json.data;",
                  "",
                  "pm.test('[HTTP] Status 200', () => pm.response.to.have.status(200));",
                  "// ── Cấu trúc ApiResponse ─────────────────────────────",
                  "pm.test('[Struct] res.code == 200', () => {",
                  "  pm.expect(json.code).to.eql(200);",
                  "});",
                  "pm.test('[Struct] res.message là string không rỗng', () => {",
                  "  pm.expect(json.message).to.be.a('string').and.not.empty;",
                  "});",
                  "pm.test('[Struct] res.timestamp tồn tại', () => {",
                  "  pm.expect(json.timestamp).to.exist;",
                  "});",
                  "pm.test('[Business] data.totalOrders là number >= 0', () => pm.expect(d.totalOrders).to.be.a('number').and.at.least(0));",
                  "pm.test('[Business] data.statusBreakdown là array', () => pm.expect(d.statusBreakdown).to.be.an('array'));",
                  "pm.test('[Business] statusBreakdown có đúng 6 trạng thái', () => pm.expect(d.statusBreakdown.length).to.eql(6));",
                  "pm.test('[Business] Mỗi phần tử có status, count, percentage', () => {",
                  "  const validStatuses = ['PENDING','CONFIRMED','SAMPLE_COLLECTED','ANALYZING','COMPLETED','CANCELLED'];",
                  "  d.statusBreakdown.forEach(item => {",
                  "    pm.expect(item).to.have.all.keys('status','count','percentage');",
                  "    pm.expect(validStatuses).to.include(item.status);",
                  "    pm.expect(item.count).to.be.a('number').and.at.least(0);",
                  "    pm.expect(item.percentage).to.match(/%$/);",
                  "  });",
                  "});",
                  "pm.test('[Business] Tổng count của tất cả status == totalOrders', () => {",
                  "  const sum = d.statusBreakdown.reduce((s, i) => s + i.count, 0);",
                  "  pm.expect(sum).to.eql(d.totalOrders);",
                  "});",
                  "pm.test('[Business] Không có status trùng lặp', () => {",
                  "  const statuses = d.statusBreakdown.map(i => i.status);",
                  "  pm.expect(new Set(statuses).size).to.eql(statuses.length);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
