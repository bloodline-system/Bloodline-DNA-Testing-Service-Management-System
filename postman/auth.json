  "item": [
    {
      "name": "Sign Up",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Lưu signup-id\", () => {",
              "  const body = pm.response.json();",
              "  pm.expect(body.data[\"sign-up-id\"]).to.be.a(\"string\");",
              "  pm.environment.set(\"signup-id\", body.data[\"sign-up-id\"]);",
              "});",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let username = pm.variables.replaceIn(\"{{$randomUserName}}\");",
              "let email = pm.variables.replaceIn(\"{{$randomEmail}}\");",
              "let password = pm.variables.replaceIn(\"{{$randomPassword}}\");",
              "",
              "pm.environment.set(\"username\", username);",
              "pm.environment.set(\"email\", email);",
              "pm.environment.set(\"password\", password);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"{{username}}\",\r\n  \"password\": \"{{password}}\",\r\n  \"email\": \"{{email}}\",\r\n  \"firstName\": \"Tinh\",\r\n  \"lastName\": \"Huynh\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/sign-up",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "sign-up"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Resend OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseCode = pm.response.json().code;",
              "",
              "pm.test(\"Status code is valid\", function () {",
              "    pm.expect(responseCode).to.be.oneOf([200, 202, 400]);",
              "});",
              "",
              "if (responseCode === 200 || responseCode === 202) {",
              "    pm.test(\"OTP email sent successfully\", function () {",
              "        pm.expect(pm.response.text()).to.include(\"User verification email sent successfully\");",
              "    });",
              "} else if (responseCode === 400) {",
              "    pm.test(\"Rate limit response is valid\", function () {",
              "        const body = pm.response.json();",
              "        pm.expect(body).to.have.property(\"code\", 400);",
              "        pm.expect(body).to.have.property(\"message\");",
              "        pm.expect(body.message).to.include(\"Please wait\");",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/resend-otp?signUpId={{signup-id}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "resend-otp"
          ],
          "query": [
            {
              "key": "signUpId",
              "value": "{{signup-id}}"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Debug Get OTP Signup",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Check if OTP is present\", function () {\r",
              "    var body = pm.response.json();\r",
              "    pm.expect(body.data[\"otp_code\"]).to.be.a(\"string\");\r",
              "    pm.expect(body.data[\"otp_code\"]).to.have.lengthOf(6);\r",
              "    pm.environment.set(\"otp_code\", body.data[\"otp_code\"]); // Store OTP in environment variable for further use\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/debug/otp/{{signup-id}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "debug",
            "otp",
            "{{signup-id}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Verification OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Body matches string\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"User verified successfully\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"signUpId\": \"{{signup-id}}\",\n  \"otp\": \"{{otp_code}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/verification",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "verification"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "if (jsonData.data) {",
              "    pm.environment.set(\"access_token\", jsonData.data.access_token);",
              "    pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
              "    pm.environment.set(\"expires_in\", jsonData.data.expires_in);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"{{username}}\",\r\n  \"password\": \"{{password}}\",\r\n  \"rememberMe\": true\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Refresh Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "if (jsonData.code === 200) {\r",
              "    pm.test(\"Access token is present\", function () {\r",
              "        pm.expect(jsonData.data.access_token).to.not.be.null;\r",
              "    });\r",
              "\r",
              "    pm.test(\"Refresh token is present\", function () {\r",
              "        pm.expect(jsonData.data.refresh_token).to.not.be.null;\r",
              "        });\r",
              "\r",
              "    pm.test(\"Add token to environment variables\", function () {\r",
              "        pm.environment.set(\"access_token\", jsonData.data.access_token);\r",
              "        pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);\r",
              "        pm.environment.set(\"expires_in\", jsonData.data.expires_in);\r",
              "    });\r",
              "\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
