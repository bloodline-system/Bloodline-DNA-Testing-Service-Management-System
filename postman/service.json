{
  "info": {
    "_postman_id": "5e923162-d594-4ec1-b86d-039bb744400c",
    "name": "Service Management API",
    "description": "Minimal Service Management API collection with only login request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.environment.set(\"access_token\", jsonData.data.access_token);",
              "pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
              "pm.environment.set(\"expires_in\", jsonData.data.expires_in);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\\n  \\\"username\\\": \\\"{{username}}\\\",\\n  \\\"password\\\": \\\"{{password}}\\\",\\n  \\\"rememberMe\\\": true\\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    }
  ]
}