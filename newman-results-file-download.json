                "script": {
                  "id": "a09b211b-f094-42b1-b05e-bdf954c0bc54",
                  "type": "text/javascript",
                  "exec": [
                    "pm.test('Status code is 200 or 404 or connection failed', function () {",
                    "    if (pm.response.code === undefined) {",
                    "        pm.expect(true).to.be.true;",
                    "    } else {",
                    "        pm.expect([200, 404]).to.include(pm.response.code);",
                    "    }",
                    "});",
                    "pm.test('Download response is either binary or not found or connection failed', function () {",
                    "    if (pm.response.code === undefined) {",
                    "        pm.expect(true).to.be.true;",
                    "    } else if (pm.response.code === 200) {",
                    "        var contentType = pm.response.headers.get('Content-Type');",
                    "        pm.expect(contentType).to.not.be.null;",
                    "    } else {",
                    "        pm.expect(pm.response.text()).to.include('Not Found');",
                    "    }",
                    "});"
                  ],
                  "_lastExecutionId": "1d90a640-bd81-476a-a218-e1a1162489c6"
                }
              }
