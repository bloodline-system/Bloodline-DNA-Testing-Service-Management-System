              {
                "listen": "prerequest",
                "script": {
                  "id": "8a340e45-2c4c-4415-9774-cf4def1fb2fb",
                  "type": "text/javascript",
                  "exec": [
                    "var token = pm.collectionVariables.get('access_token') || pm.environment.get('access_token');",
                    "if (token) {",
                    "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
                    "} else {",
                    "    console.warn('access_token missing; run Login first');",
                    "}"
                  ],
                  "_lastExecutionId": "77b6f994-bd53-4ae3-86f2-38e54f3a2a17"
