    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "if (jsonData.data) {",
              "    pm.environment.set(\"access_token\", jsonData.data.access_token);",
              "    pm.environment.set(\"refresh_token\", jsonData.data.refresh_token);",
              "    pm.environment.set(\"expires_in\", jsonData.data.expires_in);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Tự động refresh token nếu hết hạn",
              "const token = pm.environment.get(\"access_token\");",
              "const expiresIn = pm.environment.get(\"expires_in\");",
              "",
              "// expires_in là date string dạng \"Sun Mar 15 15:31:29 GMT+07:00 2026\"",
              "const expiry = expiresIn ? new Date(expiresIn).getTime() : 0;",
              "",
              "if (!token || Date.now() > expiry) {",
              "  // Gọi API refresh token",
              "  pm.sendRequest({",
              "    url: pm.environment.get(\"baseUrl\") + \"/api/v1/auth/refresh\",",
              "    method: \"POST\",",
              "    header: { \"Content-Type\": \"application/json\" },",
              "    body: {",
              "      mode: \"raw\",",
              "      raw: JSON.stringify({ token: pm.environment.get(\"refresh_token\") })",
              "    }",
              "  }, (err, res) => {",
              "    if (!err && res) {",
              "      const data = res.json().data;",
              "      if (data) {",
              "        pm.environment.set(\"access_token\", data.access_token);",
              "        pm.environment.set(\"refresh_token\", data.refresh_token);",
              "        pm.environment.set(\"expires_in\", data.expires_in);",
              "      }",
              "    }",
              "  });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"username\": \"string2\",\r\n  \"password\": \"stringst\",\r\n  \"rememberMe\": true\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Logout",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Tự động refresh token nếu hết hạn\r",
              "const token = pm.environment.get(\"access_token\");\r",
              "const expiresIn = pm.environment.get(\"expires_in\");\r",
              "\r",
              "// expires_in là date string dạng \"Sun Mar 15 15:31:29 GMT+07:00 2026\"\r",
              "const expiry = expiresIn ? new Date(expiresIn).getTime() : 0;\r",
              "\r",
              "if (!token || Date.now() > expiry) {\r",
              "  // Gọi API refresh token\r",
              "    try {\r",
              "        const response = await pm.execution.runRequest(\"34182990-fd961599-b8e3-4e9c-ba48-98b2d7a73aeb\");\r",
              "\r",
              "        console.log(response.json());\r",
              "    } catch (err) {\r",
              "        console.error(err);\r",
              "    }\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {
              "34182990-fd961599-b8e3-4e9c-ba48-98b2d7a73aeb": {
                "workspace": "9cdfda82-5f5a-49d5-9fd1-3a9b5197bbd8",
                "collection": "34182990-97f2d62c-1e51-4ec9-92a8-65d4c366d453",
                "location": [
                  "Auth API",
                  "Refresh Token"
                ]
              }
            }
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Body matches string\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Logout successfully\");\r",
              "});\r",
              "\r",
              "pm.environment.unset(\"access_token\");\r",
              "pm.environment.unset(\"refresh_token\");\r",
              "pm.environment.unset(\"expires_in\")"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
