    {
      "name": "Resend OTP",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const responseCode = pm.response.code;",
              "",
              "pm.test(\"Status code is valid\", function () {",
              "    pm.expect(responseCode).to.be.oneOf([200, 202, 400]);",
              "});",
              "",
              "if (responseCode === 200 || responseCode === 202) {",
              "    pm.test(\"OTP email sent successfully\", function () {",
              "        pm.expect(pm.response.text()).to.include(\"User verification email sent successfully\");",
              "    });",
              "} else if (responseCode === 400) {",
              "    pm.test(\"Rate limit response is valid\", function () {",
              "        const body = pm.response.json();",
              "        pm.expect(body).to.have.property(\"code\", 400);",
              "        pm.expect(body).to.have.property(\"message\");",
              "        pm.expect(body.message).to.include(\"Please wait\");",
              "    });",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
